<addon id="repository.fenlight" name="Fen Light Repository" provider-name="Fen Light" version="1.0.0">
    <extension point="xbmc.addon.repository" name="Fen Light Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/TechXXX/kodirepo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/TechXXX/kodirepo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/TechXXX/kodirepo/main/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Repository for Fen Light Kodi add-ons.</summary>
        <description lang="en">Install this repository to receive Fen Light Kodi add-on updates from a GitHub Pages-hosted source.</description>
        <platform>all</platform>
    </extension>
</addon>
