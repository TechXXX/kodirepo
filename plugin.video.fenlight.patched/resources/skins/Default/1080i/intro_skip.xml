<?xml version="1.0" encoding="UTF-8"?>
<window>
    <onload>Dialog.Close(fullscreeninfo,true)</onload>
    <onload>Dialog.Close(videoosd,true)</onload>
    <animation effect="fade" end="100" time="250">WindowOpen</animation>
    <controls>
        <control type="image">
            <height>360</height>
            <texture>fenlight_common/dim-top.png</texture>
        </control>
        <control type="group">
            <left>20</left>
            <top>20</top>
            <height>160</height>
            <control type="image">
                <left>-1</left>
                <top>-1</top>
                <width>286</width>
                <height>162</height>
                <texture border="16" colordiffuse="FFCCCCCC">fenlight_common/dialog.png</texture>
            </control>
            <control type="image">
                <width>284</width>
                <texture colordiffuse="FF000000" diffuse="fenlight_diffuse/landscape_w284_h160.png">fenlight_common/white.png</texture>
            </control>
            <control type="image">
                <width>284</width>
                <aspectratio>scale</aspectratio>
                <texture diffuse="fenlight_diffuse/landscape_w284_h160.png">$INFO[Window.Property(thumb)]</texture>
                <animation effect="fade" end="65">WindowOpen</animation>
            </control>
            <control type="image">
                <top>80</top>
                <left>72</left>
                <width>140</width>
                <texture>$INFO[Window.Property(clearlogo)]</texture>
                <aspectratio>keep</aspectratio>
                <animation effect="fade" end="80">WindowOpen</animation>
            </control>
            <control type="group">
                <left>275</left>
                <control type="group">
                    <control type="image">
                        <left>30</left>
                        <top>0</top>
                        <width>45</width>
                        <height>45</height>
                        <align>left</align>
                        <aligny>top</aligny>
                        <aspectratio aligny="top">keep</aspectratio>
                        <texture colordiffuse="FFB7B4BB">fenlight_common/baslite.png</texture>
                    </control>
                    <control type="label">
                        <left>80</left>
                        <aligny>center</aligny>
                        <height>40</height>
                        <label>[B]$INFO[Window.Property(segment_label)][/B]</label>
                        <font>font14</font>
                        <textcolor>FFB7B4BB</textcolor>
                    </control>
                </control>
                <control type="label">
                    <top>45</top>
                    <left>35</left>
                    <height>35</height>
                    <width>auto</width>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>$INFO[Window.Property(episode_label)]</label>
                    <font>font10</font>
                    <textcolor>FFB7B4BB</textcolor>
                </control>
                <control type="grouplist">
                    <left>30</left>
                    <top>100</top>
                    <width>350</width>
                    <height>70</height>
                    <orientation>horizontal</orientation>
                    <itemgap>10</itemgap>
                    <control type="button" id="11">
                        <description>$INFO[Window.Property(button_skip_label)]</description>
                        <width>160</width>
                        <height>60</height>
                        <onright>12</onright>
                        <label>$INFO[Window.Property(button_skip_label)]</label>
                        <font>font10</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <focusedcolor>FF1F2020</focusedcolor>
                        <texturefocus colordiffuse="FFCCCCCC" border="30">fenlight_common/circle.png</texturefocus>
                        <texturenofocus colordiffuse="FF4a4347" border="30">fenlight_common/circle.png</texturenofocus>
                        <align>center</align>
                        <aligny>center</aligny>
                    </control>
                    <control type="button" id="12">
                        <description>$INFO[Window.Property(button_close_label)]</description>
                        <width>160</width>
                        <height>60</height>
                        <onleft>11</onleft>
                        <label>$INFO[Window.Property(button_close_label)]</label>
                        <font>font10</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <focusedcolor>FF1F2020</focusedcolor>
                        <texturefocus colordiffuse="FFCCCCCC" border="30">fenlight_common/circle.png</texturefocus>
                        <texturenofocus colordiffuse="FF4a4347" border="30">fenlight_common/circle.png</texturenofocus>
                        <align>center</align>
                        <aligny>center</aligny>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>
