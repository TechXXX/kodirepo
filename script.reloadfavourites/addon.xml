<?xml version="1.0" encoding="UTF-8"?>
<addon id="script.reloadfavourites" name="Reload Favourites" version="1.0.0" provider-name="Bas">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Reload the Master user profile.</summary>
        <description lang="en_GB">A minimal program addon that runs the Kodi builtin to load the Master user profile.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
